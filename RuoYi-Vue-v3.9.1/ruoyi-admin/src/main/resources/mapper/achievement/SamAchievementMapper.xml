    <sql id="selectSamAchievementVo">
        select
            a.achievement_id,
            a.session_id,
            s.competition_id as competition_id,
            c.name as competition_name,
            a.category,
            a.name,
            a.team_name,
            p_view.contestant,
            ad_view.instructor,
            a.level,
            a.grade,
            a.track,
            a.certificate_no,
            a.group_id,
            a.award_time,
            a.year,
            a.owner_dep_id,
            a.is_reimburse,
            a.is_supplement,
            a.fee,
            a.reimbursement_fee,
            a.reimbursement_ratio,
            a.reimbursement_item_id,
            a.reimbursement_date,
            a.item_index,
            a.quality_index,
            a.submitted_at,
            a.reviewed_at,
            a.school_reviewed_at,
            a.review_result,
            a.schooi_review_result,
            a.review_reason,
            a.school_review_reason,
            a.audit_by,
            a.school_audit_by,
            a.create_by,
            a.update_by,
            a.create_time,
            a.update_time,
            a.del_flag,
            a.remark
        from sam_achievement a
                 left join sam_competition_session s on a.session_id = s.session_id
                 left join sam_competition c on s.competition_id = c.id
                 left join (
                    select
                        p.achievement_id,
                        group_concat(concat(ifnull(s.name, '-'), '(', ifnull(p.student_id, '-'), ')') order by p.order_no separator '，') as contestant
                    from sam_achievement_participant p
                             left join sam_student s on p.student_id = s.no
                    group by p.achievement_id
                 ) p_view on p_view.achievement_id = a.achievement_id
                 left join (
                    select
                        ad.achievement_id,
                        group_concat(concat(ifnull(t.teacher_name, '-'), '(', ifnull(ad.teacher_id, '-'), ')') order by ad.order_no separator '，') as instructor
                    from sam_achievement_advisor ad
                             left join sam_teacher t on ad.teacher_id = t.no
                    group by ad.achievement_id
                 ) ad_view on ad_view.achievement_id = a.achievement_id
    </sql>

    <select id="selectSamAchievementList" parameterType="SamAchievement" resultMap="SamAchievementListResult">
        <include refid="selectSamAchievementVo"/>
        <where>
            <if test="achievementId != null  and achievementId != ''"> and a.achievement_id = #{achievementId}</if>
            <if test="competitionId != null  and competitionId != ''"> and s.competition_id = #{competitionId}</if>
            <if test="sessionId != null  and sessionId != ''"> and a.session_id = #{sessionId}</if>
            <if test="category != null  and category != ''"> and a.category like concat('%', #{category}, '%')</if>
            <if test="name != null  and name != ''"> and a.name like concat('%', #{name}, '%')</if>
            <if test="teamName != null  and teamName != ''"> and a.team_name like concat('%', #{teamName}, '%')</if>
            <if test="level != null  and level != ''"> and a.level = #{level}</if>
            <if test="grade != null "> and a.grade = #{grade}</if>
            <if test="track != null  and track != ''"> and a.track like concat('%', #{track}, '%')</if>
            <if test="certificateNo != null  and certificateNo != ''"> and a.certificate_no = #{certificateNo}</if>
            <if test="groupId != null "> and a.group_id = #{groupId}</if>
            <if test="awardTime != null "> and a.award_time = #{awardTime}</if>
        </where>
    </select>

    <select id="selectSamAchievementListByStudentId" parameterType="SamAchievement" resultMap="SamAchievementListResult">
        <include refid="selectSamAchievementVo"/>
        inner join sam_achievement_participant p on a.achievement_id = p.achievement_id
        <where>
            and p.student_id = #{params.studentId}
            <if test="params.manager != null and params.manager != ''"> and p.manager = #{params.manager}</if>
            <if test="name != null  and name != ''"> and a.name like concat('%', #{name}, '%')</if>
            <if test="reviewResult != null  and reviewResult != ''"> and a.review_result = #{reviewResult}</if>
        </where>
    </select>

    <select id="selectSamAchievementListByResponsibleStudentId" parameterType="SamAchievement" resultMap="SamAchievementListResult">
        <include refid="selectSamAchievementVo"/>
        inner join sam_achievement_participant p on a.achievement_id = p.achievement_id
        <where>
            and p.student_id = #{params.studentId}
            and p.manager = '1'
            <if test="name != null  and name != ''"> and a.name like concat('%', #{name}, '%')</if>
            <if test="reviewResult != null  and reviewResult != ''"> and a.review_result = #{reviewResult}</if>
        </where>
    </select>

    <select id="selectSamAchievementListByTeacherId" parameterType="SamAchievement" resultMap="SamAchievementListResult">
        <include refid="selectSamAchievementVo"/>
        inner join sam_achievement_advisor ad on a.achievement_id = ad.achievement_id
        <where>
            and ad.teacher_id = #{params.teacherId}
            <if test="params.isFirst != null and params.isFirst == 1"> and ad.order_no = 1</if>
            <if test="name != null  and name != ''"> and a.name like concat('%', #{name}, '%')</if>
            <if test="reviewResult != null  and reviewResult != ''"> and a.review_result = #{reviewResult}</if>
        </where>
    </select>

    <select id="selectSamAchievementListByUserId" parameterType="SamAchievement" resultMap="SamAchievementListResult">
        <include refid="selectSamAchievementVo"/>
        <where>
            (
                exists (select 1 from sam_achievement_participant p where p.achievement_id = a.achievement_id and p.student_id = #{params.userId})
                or
                exists (select 1 from sam_achievement_advisor ad where ad.achievement_id = a.achievement_id and ad.teacher_id = #{params.userId})
            )
            <if test="name != null  and name != ''"> and a.name like concat('%', #{name}, '%')</if>
            <if test="reviewResult != null  and reviewResult != ''"> and a.review_result = #{reviewResult}</if>
        </where>
    </select>

    <select id="selectSamAchievementByAchievementId" parameterType="String" resultMap="SamAchievementSamAchievementParticipantResult">
        <include refid="selectSamAchievementVo"/>
        where a.achievement_id = #{achievementId}
    </select>

    <select id="selectSamAchievementParticipantList" resultMap="SamAchievementParticipantResult">
