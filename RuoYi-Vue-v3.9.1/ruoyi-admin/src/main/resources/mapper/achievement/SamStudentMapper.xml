<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.achievement.mapper.SamStudentMapper">
    
    <resultMap type="SamStudent" id="SamStudentResult">
        <result property="studentId"    column="student_id"    />
        <result property="name"    column="name"    />
        <result property="no"    column="no"    />
        <result property="school"    column="school"    />
        <result property="department"    column="department"    />
        <result property="major"    column="major"    />
        <result property="schoolName"    column="school_name"    />
        <result property="departmentName"    column="department_name"    />
        <result property="majorName"    column="major_name"    />
        <result property="className"    column="class_name"    />
        <result property="classYear"    column="class_year"    />
    </resultMap>

    <sql id="selectSamStudentVo">
        select s.student_id, s.name, s.no, s.school, s.department, s.major, s.class_name, s.class_year,
               d1.dept_name as school_name, d2.dept_name as department_name, d3.dept_name as major_name
        from sam_student s
        left join sys_dept d1 on s.school = d1.dept_id
        left join sys_dept d2 on s.department = d2.dept_id
        left join sys_dept d3 on s.major = d3.dept_id
    </sql>

    <select id="selectSamStudentList" parameterType="SamStudent" resultMap="SamStudentResult">
        <include refid="selectSamStudentVo"/>
        <where>  
            <if test="name != null  and name != ''"> and s.name like concat('%', #{name}, '%')</if>
            <if test="no != null  and no != ''"> and s.no = #{no}</if>
            <if test="school != null  and school != ''"> and d1.dept_name like concat('%', #{school}, '%')</if>
            <if test="department != null  and department != ''"> and d2.dept_name like concat('%', #{department}, '%')</if>
            <if test="major != null  and major != ''"> and d3.dept_name like concat('%', #{major}, '%')</if>
            <if test="className != null  and className != ''"> and s.class_name like concat('%', #{className}, '%')</if>
            <if test="classYear != null  and classYear != ''"> and s.class_year = #{classYear}</if>
        </where>
    </select>
    
    <select id="selectSamStudentByStudentId" parameterType="Long" resultMap="SamStudentResult">
        <include refid="selectSamStudentVo"/>
        where s.student_id = #{studentId}
    </select>

    <insert id="insertSamStudent" parameterType="SamStudent" useGeneratedKeys="true" keyProperty="studentId">
        insert into sam_student
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="no != null and no != ''">no,</if>
            <if test="school != null">school,</if>
            <if test="department != null">department,</if>
            <if test="major != null">major,</if>
            <if test="className != null">class_name,</if>
            <if test="classYear != null">class_year,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="no != null and no != ''">#{no},</if>
            <if test="school != null">#{school},</if>
            <if test="department != null">#{department},</if>
            <if test="major != null">#{major},</if>
            <if test="className != null">#{className},</if>
            <if test="classYear != null">#{classYear},</if>
         </trim>
    </insert>

    <update id="updateSamStudent" parameterType="SamStudent">
        update sam_student
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="no != null and no != ''">no = #{no},</if>
            <if test="school != null">school = #{school},</if>
            <if test="department != null">department = #{department},</if>
            <if test="major != null">major = #{major},</if>
            <if test="className != null">class_name = #{className},</if>
            <if test="classYear != null">class_year = #{classYear},</if>
        </trim>
        where student_id = #{studentId}
    </update>

    <delete id="deleteSamStudentByStudentId" parameterType="Long">
        delete from sam_student where student_id = #{studentId}
    </delete>

    <delete id="deleteSamStudentByStudentIds" parameterType="String">
        delete from sam_student where student_id in 
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>

    <select id="selectSamStudentByNo" parameterType="String" resultMap="SamStudentResult">
        <include refid="selectSamStudentVo"/>
        where no = #{no}
    </select>
</mapper>