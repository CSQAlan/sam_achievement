        </trim>
    </insert>

    <!-- 新增：补全缺失的批量插入附件SQL节点（核心修复）- 添加自增ID配置 -->
    <insert id="batchCompetitionApplyAttachment" parameterType="java.util.List" useGeneratedKeys="true" keyProperty="id">
        insert into sam_competition_apply_attachment
        (competition_apply_id, uuid,  document_name, attachment_type, create_by, create_time, update_by, update_time, del_flag)
        values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.competitionApplyId},
            #{item.uuid},

            #{item.documentName},
            #{item.attachmentType},
            #{item.createBy},
            #{item.createTime},
            #{item.updateBy},
            #{item.updateTime},
            #{item.delFlag}
            )
        </foreach>
    </insert>

    <!-- 附件预览相关查询 -->
    <select id="selectCompetitionApplyAttachmentById" parameterType="Long" resultMap="CompetitionApplyAttachmentResult">
        select id, competition_apply_id, uuid, document_name, attachment_type, create_by, create_time, update_by, update_time, del_flag
        from sam_competition_apply_attachment
        where id = #{attachmentId}
    </select>

    <select id="selectCompetitionApplyAttachmentListByApplyId" parameterType="Long" resultMap="CompetitionApplyAttachmentResult">
        select id, competition_apply_id, uuid, document_name, attachment_type, create_by, create_time, update_by, update_time, del_flag
        from sam_competition_apply_attachment
        where competition_apply_id = #{applyId} and del_flag = '0'
    </select>

</mapper>
