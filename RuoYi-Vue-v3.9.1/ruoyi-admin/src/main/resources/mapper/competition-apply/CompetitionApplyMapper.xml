<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.competitionapply.mapper.CompetitionApplyMapper">

    <!-- 主表结果映射（完全匹配 CompetitionApply 实体类） -->
    <resultMap type="CompetitionApply" id="CompetitionApplyResult">
        <result property="id"           column="id"                />
        <result property="applicantUserId" column="applicant_user_id" />
        <result property="applicantDepId"  column="applicant_dep_id"  />
        <result property="name"         column="name"              />
        <result property="session"      column="session"           />
        <result property="year"         column="year"              />
        <result property="category"     column="category"          />
        <result property="organizations" column="organizations"     />
        <result property="level"        column="level"             />
        <result property="scopeType"    column="scope_type"        />
        <result property="status"       column="status"            />
        <result property="tags"         column="tags"              />
        <result property="memo"         column="memo"              />
        <result property="auditBy"      column="audit_by"          />
        <result property="auditTime"    column="audit_time"        />
        <result property="auditRemark"  column="audit_remark"      />
        <result property="competitionId" column="competition_id"    />
        <result property="sessionId"    column="session_id"        />
        <result property="createBy"     column="create_by"         />
        <result property="createTime"   column="create_time"       />
        <result property="updateBy"     column="update_by"         />
        <result property="updateTime"   column="update_time"       />
        <result property="remark"       column="remark"            />
        <result property="delFlag"      column="del_flag"          />
        <result property="userName"     column="user_name"         />
        <result property="deptName"     column="dept_name"         />
    </resultMap>

    <!-- 主表+子表关联结果映射 -->
    <resultMap id="CompetitionApplyCompetitionApplyAttachmentResult" type="CompetitionApply" extends="CompetitionApplyResult">
        <collection property="competitionApplyAttachmentList" ofType="CompetitionApplyAttachment" column="id" select="selectCompetitionApplyAttachmentList" />
    </resultMap>

    <!-- 子表结果映射（完全匹配 CompetitionApplyAttachment 实体类） -->
    <resultMap type="CompetitionApplyAttachment" id="CompetitionApplyAttachmentResult">
        <result property="id"              column="id"                   />
        <result property="competitionApplyId" column="competition_apply_id" />
        <result property="uuid"            column="uuid"                 />

        <result property="documentName"    column="document_name"        />
        <result property="attachmentType"  column="attachment_type"      />
        <result property="createBy"        column="create_by"            />
        <result property="createTime"      column="create_time"          />
        <result property="updateBy"        column="update_by"            />
        <result property="updateTime"      column="update_time"          />
        <result property="delFlag"         column="del_flag"             />
    </resultMap>

    <!-- 主表查询公共SQL -->
    <sql id="selectCompetitionApplyVo">
        select
        a.id,
        a.applicant_user_id,
        a.applicant_dep_id,
        a.name,
        a.session,
        a.year,
        a.category,
        a.organizations,
        a.level,
        a.scope_type,
        a.status,
        a.tags,
        a.memo,
        a.audit_by,
        a.audit_time,
        a.audit_remark,
        a.competition_id,
        a.session_id,
        a.create_by,
        a.create_time,
        a.update_by,
        a.update_time,
        a.remark,
        a.del_flag,
        u.user_name as user_name,
        d.dept_name as dept_name
        from sam_competition_apply a
        left join sys_user u on a.applicant_user_id = u.user_id
        left join sys_dept d on a.applicant_dep_id = d.dept_id
    </sql>

    <!-- 主表列表查询 -->
    <select id="selectCompetitionApplyList" parameterType="CompetitionApply" resultMap="CompetitionApplyResult">
        <include refid="selectCompetitionApplyVo"/>
        <where>
            <!-- applicantUserId/applicantDepId：按ID精确匹配（用于后端强约束/精确过滤） -->
            <if test="applicantUserId != null and applicantUserId != ''">
                and a.applicant_user_id = #{applicantUserId}
            </if>
            <if test="applicantDepId != null and applicantDepId != ''">
                and a.applicant_dep_id = #{applicantDepId}
            </if>
            <!-- userName/deptName：按展示名称模糊匹配（管理员筛选用） -->
            <if test="userName != null and userName != ''">
                AND u.user_name LIKE CONCAT('%', #{userName}, '%')
            </if>
            <if test="deptName != null and deptName != ''">
                AND d.dept_name LIKE CONCAT('%', #{deptName}, '%')
            </if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="session != null and session != ''"> and a.session = #{session}</if>
            <if test="year != null"> and a.year = #{year}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="level != null  and level != ''"> and level = #{level}</if>
            <if test="scopeType != null  and scopeType != ''"> and scope_type = #{scopeType}</if>
            <if test="status != null  and status != ''"> and a.status = #{status}</if>
            <!-- reviewedFlag：已审核/未审核快捷筛选；当显式传status时，以status为准 -->
            <if test="reviewedFlag != null and reviewedFlag != '' and (status == null or status == '')">
                <choose>
                    <when test="reviewedFlag == '0'">
                        and a.status = '0'
                    </when>
                    <when test="reviewedFlag == '1'">
                        and a.status in ('1','2')
                    </when>
                </choose>
            </if>
            <if test="memo != null  and memo != ''"> and a.memo = #{memo}</if>
        </where>
    </select>

    <!-- 主表单条查询（关联子表） -->
    <select id="selectCompetitionApplyById" parameterType="Long" resultMap="CompetitionApplyCompetitionApplyAttachmentResult">
        <include refid="selectCompetitionApplyVo"/>
        where a.id = #{id}
    </select>

    <!-- 子表列表查询（关联主表ID）- 修复参数名 + 新增del_flag过滤 -->
    <select id="selectCompetitionApplyAttachmentList" resultMap="CompetitionApplyAttachmentResult">
        select id, competition_apply_id, uuid,  document_name, attachment_type, create_by, create_time, update_by, update_time, del_flag
        from sam_competition_apply_attachment
        where competition_apply_id = #{id}
        and del_flag = '0'
    </select>

    <!-- 主表插入（匹配实体类字段） -->
    <insert id="insertCompetitionApply" parameterType="CompetitionApply" useGeneratedKeys="true" keyProperty="id">
        insert into sam_competition_apply
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="applicantUserId != null">applicant_user_id,</if>
            <if test="applicantDepId != null">applicant_dep_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="session != null and session != ''">session,</if>
            <if test="year != null">year,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="organizations != null and organizations != ''">organizations,</if>
            <if test="level != null and level != ''">level,</if>
            <if test="scopeType != null">scope_type,</if>
            <if test="status != null">status,</if>
            <if test="tags != null">tags,</if>
            <if test="memo != null">memo,</if>
            <if test="auditBy != null">audit_by,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="auditRemark != null">audit_remark,</if>
            <if test="competitionId != null">competition_id,</if>
            <if test="sessionId != null">session_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="applicantUserId != null">#{applicantUserId},</if>
            <if test="applicantDepId != null">#{applicantDepId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="session != null and session != ''">#{session},</if>
            <if test="year != null">#{year},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="organizations != null and organizations != ''">#{organizations},</if>
            <if test="level != null and level != ''">#{level},</if>
            <if test="scopeType != null">#{scopeType},</if>
            <if test="status != null">#{status},</if>
            <if test="tags != null">#{tags},</if>
            <if test="memo != null">#{memo},</if>
            <if test="auditBy != null">#{auditBy},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="auditRemark != null">#{auditRemark},</if>
            <if test="competitionId != null">#{competitionId},</if>
            <if test="sessionId != null">#{sessionId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <!-- 主表更新（修复：去掉a.status的表别名a.） -->
    <update id="updateCompetitionApply" parameterType="CompetitionApply">
        update sam_competition_apply
        <trim prefix="SET" suffixOverrides=",">
            <if test="applicantUserId != null">applicant_user_id = #{applicantUserId},</if>
            <if test="applicantDepId != null">applicant_dep_id = #{applicantDepId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="session != null and session != ''">session = #{session},</if>
            <if test="year != null">year = #{year},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="organizations != null and organizations != ''">organizations = #{organizations},</if>
            <if test="level != null and level != ''">level = #{level},</if>
            <if test="scopeType != null and scopeType != ''">scope_type = #{scopeType},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="memo != null">memo = #{memo},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditRemark != null">audit_remark = #{auditRemark},</if>
            <if test="competitionId != null">competition_id = #{competitionId},</if>
            <if test="sessionId != null">session_id = #{sessionId},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <!-- 主表单条删除 -->
    <delete id="deleteCompetitionApplyById" parameterType="Long">
        delete from sam_competition_apply where id = #{id}
    </delete>

    <!-- 主表批量删除 -->
    <delete id="deleteCompetitionApplyByIds" parameterType="String">
        delete from sam_competition_apply where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 子表批量删除（关联主表ID） -->
    <delete id="deleteCompetitionApplyAttachmentByApplyIds" parameterType="String">
        delete from sam_competition_apply_attachment where competition_apply_id in
        <foreach item="competitionApplyId" collection="array" open="(" separator="," close=")">
            #{competitionApplyId}
        </foreach>
    </delete>

    <!-- 子表单条删除（关联主表ID）（修复：参数从competitionApplyId改为id） -->
    <delete id="deleteCompetitionApplyAttachmentByApplyId" parameterType="Long">
        delete from sam_competition_apply_attachment where competition_apply_id = #{id}
    </delete>

    <!-- 子表单条插入（匹配实体类字段） -->
    <insert id="insertCompetitionApplyAttachment" parameterType="CompetitionApplyAttachment">
        insert into sam_competition_apply_attachment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
