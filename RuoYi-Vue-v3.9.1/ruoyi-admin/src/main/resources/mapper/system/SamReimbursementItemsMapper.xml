<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SamReimbursementItemsMapper">
    
    <resultMap type="SamReimbursementItems" id="SamReimbursementItemsResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="reimbursementTime"    column="reimbursement_time"    />
        <result property="totalFee"    column="total_fee"    />
        <result property="paidFee"    column="paid_fee"    />
        <result property="amount"    column="amount"    />
        <result property="ownerDepId"    column="owner_dep_id"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="actualAmount"    column="actual_amount"    />
        <result property="actualTotalFee"    column="actual_total_fee"    />
        <result property="actualPaidFee"    column="actual_paid_fee"    />
    </resultMap>

    <sql id="selectSamReimbursementItemsVo">
        select id, name, reimbursement_time, total_fee, paid_fee, amount, owner_dep_id, status, create_by, create_time, update_by, update_time, remark, del_flag from sam_reimbursement_items
    </sql>

    <select id="selectSamReimbursementItemsList" parameterType="SamReimbursementItems" resultMap="SamReimbursementItemsResult">
        SELECT 
            i.id,
            i.name,
            i.reimbursement_time,
            i.total_fee,
            i.paid_fee,
            i.amount,
            i.owner_dep_id,
            i.status,
            i.create_by,
            i.create_time,
            i.update_by,
            i.update_time,
            i.remark,
            i.del_flag,
            -- 添加子查询：统计关联的成果数量
            (SELECT COUNT(*) FROM sam_achievement a 
             WHERE a.reimbursement_item_id = i.id 
               AND a.del_flag = '0') AS actual_amount,
            -- 添加子查询：统计关联成果的总报销金额
            (SELECT COALESCE(SUM(a.reimbursement_fee), 0) FROM sam_achievement a 
             WHERE a.reimbursement_item_id = i.id 
               AND a.del_flag = '0') AS actual_total_fee,
            -- 添加子查询：统计已发放金额
            (SELECT COALESCE(SUM(a.reimbursement_fee), 0) FROM sam_achievement a 
             WHERE a.reimbursement_item_id = i.id 
               AND a.del_flag = '0'
               AND a.is_reimburse = '1') AS actual_paid_fee
        FROM sam_reimbursement_items i
        WHERE i.del_flag = '0'
        <if test="name != null and name != ''">
            AND i.name LIKE CONCAT('%', #{name}, '%')
        </if>
        <if test="ownerDepId != null">
            AND i.owner_dep_id = #{ownerDepId}
        </if>
        <if test="status != null and status != ''">
            AND i.status = #{status}
        </if>
        ORDER BY i.create_time DESC
    </select>
    
    <select id="selectSamReimbursementItemsById" parameterType="Long" resultMap="SamReimbursementItemsResult">
        <include refid="selectSamReimbursementItemsVo"/>
        where id = #{id}
    </select>

    <insert id="insertSamReimbursementItems" parameterType="SamReimbursementItems" useGeneratedKeys="true" keyProperty="id">
        insert into sam_reimbursement_items
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="reimbursementTime != null">reimbursement_time,</if>
            <if test="totalFee != null">total_fee,</if>
            <if test="paidFee != null">paid_fee,</if>
            <if test="amount != null">amount,</if>
            <if test="ownerDepId != null">owner_dep_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="reimbursementTime != null">#{reimbursementTime},</if>
            <if test="totalFee != null">#{totalFee},</if>
            <if test="paidFee != null">#{paidFee},</if>
            <if test="amount != null">#{amount},</if>
            <if test="ownerDepId != null">#{ownerDepId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateSamReimbursementItems" parameterType="SamReimbursementItems">
        update sam_reimbursement_items
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="reimbursementTime != null">reimbursement_time = #{reimbursementTime},</if>
            <if test="totalFee != null">total_fee = #{totalFee},</if>
            <if test="paidFee != null">paid_fee = #{paidFee},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="ownerDepId != null">owner_dep_id = #{ownerDepId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSamReimbursementItemsById" parameterType="Long">
        delete from sam_reimbursement_items where id = #{id}
    </delete>

    <delete id="deleteSamReimbursementItemsByIds" parameterType="String">
        delete from sam_reimbursement_items where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>