    </sql>

   <!-- 根据竞赛ID查询成果列表 -->
<select id="selectByCompetitionId" parameterType="Long" resultMap="Sam_rem_ProductResult">
    SELECT 
        a.achievement_id,
        a.session_id,
        a.category,
        a.name,
        a.team_name,
        a.level,
        a.grade,
        a.track,
        a.certificate_no,
        a.group_id,
        a.award_time,
        a.year,
        a.owner_dep_id,
        a.is_reimburse,
        a.is_supplement,
        a.fee,
        a.reimbursement_fee,
        a.reimbursement_ratio,
        a.reimbursement_item_id,
        a.reimbursement_date,
        a.item_index,
        a.quality_index,
        a.submitted_at,
        a.reviewed_at,
        a.school_reviewed_at,
        a.review_result,
        a.schooi_review_result,
        a.review_reason,
        a.school_review_reason,
        a.audit_by,
        a.school_audit_by,
        a.create_by,
        a.update_by,
        a.create_time,
        a.update_time,
        a.del_flag,
        a.remark
    FROM sam_achievement a
    INNER JOIN sam_competition_session s ON a.session_id = s.id
    WHERE s.competition_id = #{competitionId}
    ORDER BY s.session DESC, a.create_time DESC
</select>

    <select id="selectSam_rem_ProductList" parameterType="Sam_rem_Product" resultMap="Sam_rem_ProductResult">
        <include refid="selectSam_rem_ProductVo"/>
        <where>  
            <if test="achievementId != null  and achievementId != ''"> and achievement_id = #{achievementId}</if>
            <if test="sessionId != null  and sessionId != ''"> and session_id = #{sessionId}</if>
            <if test="category != null  and category != ''"> and category like concat('%', #{category}, '%')</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="teamName != null  and teamName != ''"> and team_name like concat('%', #{teamName}, '%')</if>
            <if test="level != null  and level != ''"> and level = #{level}</if>
            <if test="grade != null "> and grade = #{grade}</if>
            <if test="track != null  and track != ''"> and track like concat('%', #{track}, '%')</if>
            <if test="certificateNo != null  and certificateNo != ''"> and certificate_no = #{certificateNo}</if>
            <if test="groupId != null "> and group_id = #{groupId}</if>
            <if test="awardTime != null "> and award_time = #{awardTime}</if>
        </where>
    </select>
    
