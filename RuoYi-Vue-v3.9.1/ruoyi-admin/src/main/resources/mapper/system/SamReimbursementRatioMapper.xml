<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SamReimbursementRatioMapper">
    
    <resultMap type="SamReimbursementRatio" id="SamReimbursementRatioResult">
        <result property="id"    column="id"    />
        <result property="grade"    column="grade"    />
        <result property="category"    column="category"    />
        <result property="ratio"    column="ratio"    />
        <result property="ownerDepId"    column="owner_dep_id"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectSamReimbursementRatioVo">
        select id, grade, category, ratio, owner_dep_id, status, create_by, create_time, update_by, update_time, remark, del_flag from sam_reimbursement_ratio
    </sql>

    <select id="selectSamReimbursementRatioList" parameterType="SamReimbursementRatio" resultMap="SamReimbursementRatioResult">
        <include refid="selectSamReimbursementRatioVo"/>
        <where>  
            <if test="grade != null  and grade != ''"> and grade = #{grade}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="ratio != null "> and ratio = #{ratio}</if>
            <if test="ownerDepId != null "> and owner_dep_id = #{ownerDepId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectSamReimbursementRatioById" parameterType="Long" resultMap="SamReimbursementRatioResult">
        <include refid="selectSamReimbursementRatioVo"/>
        where id = #{id}
    </select>

    <insert id="insertSamReimbursementRatio" parameterType="SamReimbursementRatio" useGeneratedKeys="true" keyProperty="id">
        insert into sam_reimbursement_ratio
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="grade != null and grade != ''">grade,</if>
            <if test="category != null">category,</if>
            <if test="ratio != null">ratio,</if>
            <if test="ownerDepId != null">owner_dep_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="grade != null and grade != ''">#{grade},</if>
            <if test="category != null">#{category},</if>
            <if test="ratio != null">#{ratio},</if>
            <if test="ownerDepId != null">#{ownerDepId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateSamReimbursementRatio" parameterType="SamReimbursementRatio">
        update sam_reimbursement_ratio
        <trim prefix="SET" suffixOverrides=",">
            <if test="grade != null and grade != ''">grade = #{grade},</if>
            <if test="category != null">category = #{category},</if>
            <if test="ratio != null">ratio = #{ratio},</if>
            <if test="ownerDepId != null">owner_dep_id = #{ownerDepId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSamReimbursementRatioById" parameterType="Long">
        delete from sam_reimbursement_ratio where id = #{id}
    </delete>

    <delete id="deleteSamReimbursementRatioByIds" parameterType="String">
        delete from sam_reimbursement_ratio where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <select id="getReimbursementRatio" resultType="java.lang.Integer">
        SELECT ratio FROM sam_reimbursement_ratio
        WHERE grade = #{grade} 
          AND category = #{category}
          AND (owner_dep_id = #{ownerDepId} OR owner_dep_id IS NULL)
          AND status = '1' AND del_flag = '0'
        ORDER BY owner_dep_id DESC LIMIT 1
    </select>
</mapper>