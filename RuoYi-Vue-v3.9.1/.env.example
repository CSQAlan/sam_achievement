# Docker Compose 环境变量配置示例
# 复制此文件为 .env 并修改为你的实际配置
# cp .env.example .env

# ============ 数据库配置 ============
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=ruoyi
MYSQL_USER=ruoyi
MYSQL_PASSWORD=your_database_password

# ============ Redis配置 ============
REDIS_PASSWORD=your_redis_password

# ============ JWT密钥（重要！必须修改） ============
# 使用以下命令生成：openssl rand -base64 64
TOKEN_SECRET=your-very-long-and-secure-jwt-secret-key-at-least-64-bytes-long

# ============ Druid监控配置 ============
DRUID_USERNAME=ruoyi
DRUID_PASSWORD=your_druid_password

# ============ 其他配置 ============
# Cookie安全配置（生产环境设为true）
COOKIE_SECURE=true

# 日志级别（生产环境建议 warn）
LOGGING_LEVEL_COM_RUOYI=info

# Swagger（生产环境设为false）
SWAGGER_ENABLED=false
